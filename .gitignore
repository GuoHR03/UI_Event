# 排除虚拟环境 (最重要的)
.qtcreator/Python_3_8_10venv/

# 排除 Qt Creator 自动生成的本地配置
.qtcreator/
*.user

# 排除 Python 缓存
__pycache__/
*.pyc

# 排除录制的大型原始数据
recordings/
*.raw
*.raw.tmp_index
*.dat

# 排除模型权重文件
app/checkpoint/
backend/Eventmamba/checkpoint/
*.pth
*.pt

# 排除构建文件
build/
*.spec
*.iss

# 排除安装脚本
install_wsl.bat
uninstall_wsl.bat
run_app.bat